<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.church.homepage.mapper.SermonMapper">

    <select id="getList" resultType="com.church.homepage.dto.SermonDTO">
        SELECT * FROM SERMON ORDER BY S_DATE DESC
    </select>

    <select id="getDetail" resultType="com.church.homepage.dto.SermonDTO">
        SELECT * FROM SERMON WHERE S_NO = #{s_no}
    </select>

</mapper>